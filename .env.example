# ============================================================
# Huyền Bí — Biến môi trường
# Sao chép file này thành .env rồi điền giá trị phù hợp
# ============================================================

# --- PostgreSQL (dùng cho Docker Compose) ---
POSTGRES_DB=huyenbi
POSTGRES_USER=huyenbi
POSTGRES_PASSWORD=huyenbi_secret_doi_mat_khau_nay

# --- Cổng web expose ra ngoài (mặc định: 80) ---
WEB_PORT=80

# --- Phiên bản image Docker build từ source app (tránh tag latest) ---
APP_VERSION=4.3.0

# --- DATABASE_URL (dùng khi cài thông thường trên VPS, không qua Docker) ---
# Với Docker Compose: URL tự động tạo từ các biến POSTGRES_* ở trên
# DATABASE_URL=postgresql://huyenbi:huyenbi_secret@localhost:5432/huyenbi

# ============================================================
# CORS — Danh sách origin được phép gọi API
# ============================================================
# Production mặc định chỉ cho phép: https://huyenbi.io.vn
# Nếu cần thêm origin khác (preview, custom domain), khai báo ở đây,
# cách nhau bằng dấu phẩy. Nếu dùng chính xác domain canonical thì
# có thể bỏ trống biến này.
# CORS_ALLOWED_ORIGINS=https://preview.huyenbi.io.vn,https://huyenbi.com

# Trong môi trường non-production, loopback (localhost / 127.0.0.1) luôn
# được cho phép để dev server gọi API mà không cần cấu hình thêm.

# ============================================================
# Trust Proxy — cấu hình khi có reverse proxy đứng trước API
# ============================================================
# Khi API chạy trực tiếp (bind 0.0.0.0, không có nginx/Caddy/LB),
# bỏ trống biến này. Rate limiter sẽ dùng IP socket thật → client
# không thể giả mạo X-Forwarded-For.
#
# Khi có reverse proxy trên cùng máy (vd: nginx/Caddy):
#   TRUST_PROXY=loopback
#
# Khi có N hop proxy đáng tin cậy (vd: CDN + LB):
#   TRUST_PROXY=2
#
# Khi muốn chỉ định subnet proxy:
#   TRUST_PROXY=10.0.0.0/8
#
# Cấu hình sai sẽ cho phép client giả mạo IP để bypass rate limit,
# nên chỉ bật khi proxy thực sự tồn tại.
# TRUST_PROXY=

# ============================================================
# Clerk Authentication — TÀI KHOẢN NGƯỜI DÙNG
# Đăng ký miễn phí tại: https://clerk.com
# Sau khi tạo app trên Clerk Dashboard, lấy keys tại:
#   Dashboard → API Keys
# ============================================================

# Secret key — dùng ở backend (KHÔNG được commit lên git)
# Lấy từ: Clerk Dashboard → API Keys → Secret keys
# CLERK_SECRET_KEY=<dán_secret_key_từ_clerk_dashboard_vào_đây>

# Publishable key — dùng ở cả frontend (build-time) VÀ backend (runtime)
# Docker compose tự dùng biến này cho cả 2 service api và web
# Lấy từ: Clerk Dashboard → API Keys → Publishable key
# VITE_CLERK_PUBLISHABLE_KEY=<dán_publishable_key_từ_clerk_dashboard_vào_đây>

# Clerk Proxy URL — CHỈ cần thiết cho Replit.app hoặc subdomain chưa CNAME
# Custom domain VPS (vd: huyenbi.com) đã verify trên Clerk Dashboard → BỎ TRỐNG dòng này
# Replit.app deployment → đặt: VITE_CLERK_PROXY_URL=https://your-app.replit.app/api/__clerk
# VITE_CLERK_PROXY_URL=

# ============================================================
# Lưu ý về AI API Key:
# Key AI (OpenAI / Google Gemini) KHÔNG cần điền ở đây.
# Admin cấu hình key trực tiếp trong giao diện web sau khi deploy:
#   Navbar → nút "AI" → Cài đặt AI → Cài đặt Admin
# ============================================================

# ============================================================
# Web Push — Nhắc nhở vận hạn (tuỳ chọn)
# ============================================================
# Bật thông báo đẩy "vận hôm nay" / sao hạn. Tạo cặp khóa VAPID một lần:
#   npx web-push generate-vapid-keys
# Rồi dán public/private vào đây. Bỏ trống = tắt tính năng nhắc nhở
# (cả API và worker tự degrade, không lỗi).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@huyenbi.io.vn
